<!-- TODO -->

<header>
  <nav class="navbar navbar-expand-sm border-bottom" style="background-color: #fdc21e;">
    <div class="container">

      <!-- Logo (top left) -->
      <a class="navbar-brand p-0" href="/dashboard">
        <img src="../resources/flatironmealplanlogo.png" alt="Flatiron Meal Plan" height="48">
      </a>

      <!-- Mobile toggle -->
      <button
        class="navbar-toggler ms-auto"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#navbar-collapse"
        aria-controls="navbar-collapse"
        aria-expanded="false"
        aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navbar-collapse">

        {{#if user}}
          <!-- Links shown only when logged in -->
          <ul class="navbar-nav me-auto">
            <li class="nav-item">
              <a class="nav-link fw-semibold {{#if (isEqual currentPage 'dashboard')}}active{{/if}}" href="/dashboard">Dashboard</a>
            </li>
            <li class="nav-item">
              <a class="nav-link fw-semibold {{#if (isEqual currentPage 'map')}}active{{/if}}" href="/map">Map</a>
            </li>
          </ul>
          <div class="nav-item me-1">
            <a class="nav-link fw-semibold" href="/logout">Logout</a>
          </div>
        {{else}}
          <!-- Links shown only when logged out -->
          <ul class="navbar-nav me-auto"></ul>
          <div class="d-flex gap-2">
            <a class="nav-link fw-semibold {{#if (isEqual currentPage 'login')}}active{{/if}}" href="/login">Login</a>
            <a class="nav-link fw-semibold {{#if (isEqual currentPage 'register')}}active{{/if}}" href="/register">Register</a>
          </div>
        {{/if}}

      </div>
    </div>
  </nav>
</header>