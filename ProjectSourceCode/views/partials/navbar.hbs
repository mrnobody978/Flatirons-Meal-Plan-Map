<header>
  <nav class="navbar navbar-expand-sm border-bottom" style="background-color: #fdc21e;">
    <div class="container">

      <!-- Logo (top left) -->
      <a class="navbar-brand p-0" href="/dashboard">
        <img src="../resources/flatironmealplanlogo.png" alt="Flatiron Meal Plan" height="48">
      </a>

      <!-- Mobile toggle -->
      <button
        class="navbar-toggler ms-auto"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#navbar-collapse"
        aria-controls="navbar-collapse"
        aria-expanded="false"
        aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navbar-collapse">

        {{#if user}}
          <!-- Links shown only when logged in -->
          <ul class="navbar-nav me-auto">
            <li class="nav-item">
              <a class="nav-link fw-semibold {{#if (isEqual currentPage 'dashboard')}}active{{/if}}" href="/dashboard">Dashboard</a>
            </li>
            <li class="nav-item">
              <a class="nav-link fw-semibold {{#if (isEqual currentPage 'map')}}active{{/if}}" href="/map">Map</a>
            </li>
          </ul>
          <div class="nav-item me-1">
            <div class="dropdown">
              <button class="btn dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                <img src="{{#if userImg}}{{userImg}}{{else}}/resources/profile.png{{/if}}" alt="Profile Image" class="profileImage" height="48" width="48">
              </button>
              <ul class="dropdown-menu">
                <li><b class="dropdown-item fw-bold">{{#if realName}}{{realName}}{{else}}{{username}}{{/if}}</b></li>
                <li><a class="dropdown-item" href="/profile">Profile</a></li>
                <li><a class="dropdown-item" href="/friends">Friends</a></li>
                <li><a class="dropdown-item" href="/logout">Logout</a></li>
              </ul>
            </div>
          </div>
        {{else}}
          <!-- Links shown only when logged out -->
          <ul class="navbar-nav me-auto"></ul>
          <div class="d-flex gap-4">
            <a class="nav-link fw-semibold {{#if (isEqual currentPage 'login')}}active{{/if}}" href="/login">Login</a>
            <a class="nav-link fw-semibold {{#if (isEqual currentPage 'register')}}active{{/if}}" href="/register">Register</a>
          </div>
        {{/if}}

      </div>
    </div>
  </nav>
</header>