<h2>Register</h2>
<form action="/register" method="post">
    <b>Username:</b>
    <input type="text" name="username" pattern="^[A-Za-z0-9_.-]{6,50}$" required><br>
    <b>Password:</b>
    <input type="text" name="password" pattern="^[^\s';]{6,50}$" required><br>
    {{> warning}}
    <br>
    <button type="submit">Sign up</button>
</form>