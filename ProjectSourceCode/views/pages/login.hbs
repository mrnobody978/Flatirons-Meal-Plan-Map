<style>
  .login-page {
    min-height: 100vh;
    background: url('/resources/login-bg.png') center center / cover no-repeat;
    display: flex;
    align-items: stretch;
    position: relative;  /* ADD THIS */
    overflow: hidden;    /* ADD THIS */
  }

  /* Dark overlay over the whole background */
  .login-page::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(0,0,0,0.62) 0%, rgba(0,0,0,0.18) 100%);
    z-index: 0;
  }

  .login-left {
    position: relative;
    z-index: 1;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 3rem 3.5rem;
    color: #fff;
  }

  .login-left .welcome-tag {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #fdc21e;
    margin-bottom: 0.75rem;
  }

  .login-left h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.6rem, 5vw, 4rem);
    font-weight: 900;
    color: #fff;
    line-height: 1.05;
    margin-bottom: 1.25rem;
  }

  .login-left h1 span {
    color: #fdc21e;
  }

  .login-left p {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    color: rgba(255,255,255,0.78);
    max-width: 360px;
    line-height: 1.65;
    margin-bottom: 2rem;
  }

  .social-links {
    display: flex;
    gap: 0.85rem;
    align-items: center;
  }

  .social-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: rgba(255,255,255,0.15);
    border: 1.5px solid rgba(255,255,255,0.3);
    color: #fff;
    font-size: 1.1rem;
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
    text-decoration: none;
  }

  .social-links a:hover {
    background: #fdc21e;
    border-color: #fdc21e;
    color: #1a1a1a;
    transform: translateY(-2px);
  }

  /* Right panel — frosted glass card */
  .login-right {
    position: relative;
    z-index: 1;
    width: 420px;
    min-width: 340px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem;
  }

  .login-card {
    background: rgba(255, 255, 255, 0.13);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: 1.4rem;
    padding: 2.5rem 2rem;
    width: 100%;
    box-shadow: 0 16px 48px rgba(0,0,0,0.35);
  }

  .login-card h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.9rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.35rem;
  }

  .login-card .subtitle {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.88rem;
    color: rgba(255,255,255,0.65);
    margin-bottom: 1.75rem;
  }

  .login-card label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.75);
    display: block;
    margin-bottom: 0.3rem;
  }

  .login-card input[type="text"],
  .login-card input[type="password"] {
    width: 100%;
    padding: 0.65rem 0.9rem;
    border-radius: 0.5rem;
    border: 1.5px solid rgba(255,255,255,0.25);
    background: rgba(255,255,255,0.12);
    color: #fff;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    margin-bottom: 1.1rem;
    transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
    outline: none;
  }

  .login-card input[type="text"]::placeholder,
  .login-card input[type="password"]::placeholder {
    color: rgba(255,255,255,0.38);
  }

  .login-card input[type="text"]:focus,
  .login-card input[type="password"]:focus {
    border-color: #fdc21e;
    background: rgba(255,255,255,0.18);
    box-shadow: 0 0 0 3px rgba(253,194,30,0.22);
  }

  .login-card input:invalid:required {
    border-color: #e05555;
  }

  .password-row {
  position: relative;
  display: flex;
  align-items: center;
  margin-bottom: 1.1rem;
}

  .password-row input {
  flex: 1;
  margin-bottom: 0 !important;
  padding-right: 3.5rem;
}

  .password-toggle {
  position: absolute;
  right: 0.75rem;
  background: none;
  border: none;
  color: rgba(255,255,255,0.55);
  cursor: pointer;
  font-size: 0.8rem;
  font-family: 'DM Sans', sans-serif;
  font-weight: 600;
  padding: 0;
  transition: color 0.2s;
}
  .password-toggle:hover { color: #fdc21e; }

  .btn-login {
    width: 100%;
    padding: 0.7rem;
    background: #fdc21e;
    border: none;
    border-radius: 0.5rem;
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: #1a1a1a;
    cursor: pointer;
    margin-top: 0.5rem;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    box-shadow: 0 3px 12px rgba(253,194,30,0.4);
    letter-spacing: 0.02em;
  }
  .btn-login:hover {
    background: #e6a800;
    transform: translateY(-1px);
    box-shadow: 0 5px 18px rgba(253,194,30,0.5);
  }

  .login-footer {
    margin-top: 1.4rem;
    text-align: center;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.88rem;
    color: rgba(255,255,255,0.6);
  }

  .login-footer a {
    color: #fdc21e;
    font-weight: 600;
    text-decoration: none;
  }
  .login-footer a:hover {
    text-decoration: underline;
    color: #fff;
  }

  /* Responsive */
  @media (max-width: 700px) {
    .login-page { flex-direction: column; }
    .login-left { padding: 2.5rem 1.5rem 1.5rem; }
    .login-left h1 { font-size: 2.2rem; }
    .login-right { width: 100%; padding: 1rem 1rem 2.5rem; }
  }
</style>

<!-- Bootstrap Icons CDN for social icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="login-page">

  <!-- Left: Branding + social -->
  <div class="login-left">
    <div class="welcome-tag">Flatiron Meal Plan</div>
    <h1>Welcome<br><span>Back.</span></h1>
    <p>Your favorite Boulder restaurants, all in one place. Log in to explore, save, and discover your next great meal.</p>
    <div class="social-links">
      <a href="https://www.instagram.com/flatironmealplan" target="_blank" aria-label="Instagram">
        <i class="bi bi-instagram"></i>
      </a>
      <a href="https://www.facebook.com/flatironmealplan" target="_blank" aria-label="Facebook">
        <i class="bi bi-facebook"></i>
      </a>
    </div>
  </div>

  <!-- Right: Login form -->
  <div class="login-right">
    <div class="login-card">
      <h2>Sign In</h2>
      <p class="subtitle">Enter your credentials to continue</p>

      <form action="/login" method="post" autocomplete="off">

        <label for="usernameInput">Username</label>
        <input
          type="text"
          name="username"
          id="usernameInput"
          placeholder="your_username"
          {{#if usernameDefault}}value="{{usernameDefault}}"{{/if}}
          required>

        <label for="passwordInput">Password</label>
        <div class="password-row">
          <input
            type="password"
            name="password"
            id="passwordInput"
            placeholder="••••••••"
            required>
          <button type="button" class="password-toggle" onclick="toggleViewPassword('passwordInput', this);">Show</button>
        </div>

        {{> warning}}

        <button type="submit" class="btn-login">Log In</button>
      </form>

      <div class="login-footer">
        Don't have an account? <a href="/register">Sign up</a>
      </div>
    </div>
  </div>

</div>

<script src="/resources/login.js"></script>


