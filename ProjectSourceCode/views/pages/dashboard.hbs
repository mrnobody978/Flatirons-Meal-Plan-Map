<div class="container p-3">
  <h1 class="text-center mb-4">Dashboard</h1>

  <div class="row g-3 text-center align-items-stretch">
    
    <div class="col-4">
      <div class="bg-light p-3 rounded-3 shadow-sm h-100">
        
        <h4>You</h4>
        <a href="/map" class="btn btn-primary mt-3">View Map</a>


      </div>
    </div>

    <div class="col-8">
      <div class="bg-body-secondary p-3 rounded-3 shadow-sm h-100">
        
        <div class="row g-3 rounded-3">
          
          <div class="col-6">
            <div class="bg-light p-3 rounded-3 shadow-sm h-100">
              <h5>Your Favorites</h5>
            </div>
          </div>

          <div class="col-6">
            <div class="bg-light p-3 rounded-3 shadow-sm h-100">
              <h5>Restaurant Recommendation</h5>
              {{#if restaurant}}
              <img src="{{restaurant.image_path}}" class="img-fluid">
              <div class="text-start p-2">
                <p>
                    <b>{{restaurant.name}}</b>
                    <br>{{restaurant.address}}
                    <br><a href="{{restaurant.website}}" target="_blank">Visit Website</a>
                </p>
              </div>
              {{else}}
              <p>No restaurant available.</p>
              {{/if}}
            </div>
          </div>

        </div>

      </div>
    </div>

  </div>
</div>